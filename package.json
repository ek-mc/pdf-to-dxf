{
  "name": "pdf-to-dxf",
  "version": "1.0.2",
  "description": "Convert PDF files to AutoCAD DXF format — React component + CLI. Part of the ek-mc civil toolset.",
  "keywords": [
    "pdf",
    "dxf",
    "autocad",
    "cad",
    "civil",
    "converter",
    "react",
    "cli",
    "pdf-to-dxf",
    "civil-toolset"
  ],
  "author": {
    "name": "ek-mc",
    "url": "https://github.com/ek-mc"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ek-mc/pdf-to-dxf.git"
  },
  "homepage": "https://github.com/ek-mc/pdf-to-dxf#readme",
  "bugs": {
    "url": "https://github.com/ek-mc/pdf-to-dxf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/pdf-to-dxf.cjs",
  "module": "./dist/pdf-to-dxf.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pdf-to-dxf.mjs",
      "require": "./dist/pdf-to-dxf.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "pdf-to-dxf": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "tsc -p tsconfig.lib.json && vite build --mode lib",
    "build:cli": "vite build --mode cli",
    "build:demo": "vite build",
    "build:ghpages": "vite build --mode ghpages",
    "build": "pnpm run build:lib && pnpm run build:cli",
    "preview": "vite preview",
    "lint": "eslint .",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@tarikjabiri/dxf": "^2.8.9",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
